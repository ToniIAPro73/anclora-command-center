{
  "name": "anclora-cuadro-de-mando-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:workbook": "node ./scripts/generate-workbook-from-notes.mjs",
    "sync:data:json": "node ./scripts/sync-dataset.mjs",
    "sync:data": "npm run generate:workbook && npm run sync:data:json",
    "dev:vite": "vite",
    "watch:notes": "node ./scripts/watch-notes-and-sync.mjs",
    "dev:watch": "concurrently -k -s first \"npm:dev:vite\" \"npm:watch:notes\"",
    "dev": "npm run dev:watch",
    "build": "npm run sync:data && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "concurrently": "^9.1.2",
    "gray-matter": "^4.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
